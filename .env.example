# ---------------------------------------------------------------------------
# Local .env — used by scripts/seed-demo-data.ts (run on your machine).
# The deployed Worker does NOT read this file; its secrets are set separately
# via `ntn workers env set` (see README).
# ---------------------------------------------------------------------------

# Notion internal integration token (the "Compass Connection" integration).
# https://www.notion.so/my-integrations
NOTION_API_KEY=

# Decision Log database ID (32-char hex from the database URL).
NOTION_DECISION_LOG_DB_ID=

# ---------------------------------------------------------------------------
# Worker secrets — set these with `ntn workers env set KEY=value` (NOT here).
# Note: env var names cannot start with "NOTION_" (reserved) EXCEPT the
# special NOTION_API_TOKEN, which authenticates the worker's Notion client.
#
#   NOTION_API_TOKEN     - the integration token (same value as NOTION_API_KEY)
#   ANTHROPIC_API_KEY    - Claude API key
#   EXA_API_KEY          - Exa search API key
#   OPPORTUNITY_DB_ID    - Opportunity Inbox database ID
#   DECISION_LOG_DB_ID   - Decision Log database ID
#   BUDGET_DB_ID         - Budget Tracker database ID
#   GITHUB_REPO_OWNER    - public repo owner for the stars-delta outcome signal
#   GITHUB_REPO_NAME     - public repo name
# ---------------------------------------------------------------------------
